    {
      "uuid": "a1b2c3d4-0000-0000-0000-000000000001",
      "title": "Valencian Paella",
      "description": "A classic Spanish rice dish loaded with saffron, fresh seafood, and seasonal vegetables.",
      "imageUrl": "https://raw.githubusercontent.com/jmuci/ChATestAPI/refs/heads/main/statics/thumbnails/lowres/paella-closeup.jpeg",
      "imageUrlThumbnail": "https://raw.githubusercontent.com/jmuci/ChATestAPI/refs/heads/main/statics/thumbnails/lowres/paella-closeup.jpeg",
      "prepTimeMinutes": 15,
      "cookTimeMinutes": 25,
      "servings": 4,
      "creatorId": "c0000000-0000-0000-0000-000000000001",
      "privacy": "PUBLIC",
      "updatedAt": 1735689600000,
      "tagIds": ["a1b2c3d4-0001-0000-0000-000000000001"],
      "labelIds": ["a1b2c3d4-0002-0000-0000-000000000001", "a1b2c3d4-0002-0000-0000-000000000002"],
      "ingredients": [
        { "name": "Short-grain rice", "quantity": 2.0, "unit": "cups" },
        { "name": "Saffron threads", "quantity": 0.5, "unit": "tsp" },
        { "name": "Chicken broth", "quantity": 4.0, "unit": "cups" },
        { "name": "Shrimp", "quantity": 200.0, "unit": "g" },
        { "name": "Mussels", "quantity": 200.0, "unit": "g" },
        { "name": "Red bell pepper", "quantity": 1.0, "unit": "whole" },
        { "name": "Olive oil", "quantity": 3.0, "unit": "tbsp" },
        { "name": "Garlic cloves", "quantity": 3.0, "unit": "whole" },
        { "name": "Smoked paprika", "quantity": 1.0, "unit": "tsp" },
        { "name": "Salt", "quantity": 1.0, "unit": "tsp" }
      ],
      "steps": [
        { "orderIndex": 1, "instruction": "Dissolve saffron in warm chicken broth and set aside." },
        { "orderIndex": 2, "instruction": "Heat olive oil in a paella pan over medium heat. Sauté garlic and red bell pepper for 2 minutes." },
        { "orderIndex": 3, "instruction": "Add smoked paprika and rice, stirring to coat in the oil for 1 minute." },
        { "orderIndex": 4, "instruction": "Pour in the saffron broth, season with salt, and bring to a boil." },
        { "orderIndex": 5, "instruction": "Nestle shrimp and mussels into the rice. Reduce heat and simmer uncovered for 18 minutes until rice is cooked and liquid is absorbed." },
        { "orderIndex": 6, "instruction": "Rest for 5 minutes before serving." }
      ]
    },
    {
      "uuid": "a1b2c3d4-0000-0000-0000-000000000002",
      "title": "Delicious Grilled Chicken",
      "description": "Juicy lemon-herb marinated chicken grilled to perfection.",
      "imageUrl": "https://raw.githubusercontent.com/jmuci/ChATestAPI/refs/heads/main/statics/thumbnails/lowres/lem-chicken.jpeg",
      "imageUrlThumbnail": "https://raw.githubusercontent.com/jmuci/ChATestAPI/refs/heads/main/statics/thumbnails/lowres/lem-chicken.jpeg",
      "prepTimeMinutes": 15,
      "cookTimeMinutes": 20,
      "servings": 4,
      "creatorId": "c0000000-0000-0000-0000-000000000001",
      "privacy": "PUBLIC",
      "updatedAt": 1735689600000,
      "tagIds": ["a1b2c3d4-0001-0000-0000-000000000002", "a1b2c3d4-0001-0000-0000-000000000003"],
      "labelIds": ["a1b2c3d4-0002-0000-0000-000000000003"],
      "ingredients": [
        { "name": "Chicken breasts", "quantity": 4.0, "unit": "whole" },
        { "name": "Lemon juice", "quantity": 3.0, "unit": "tbsp" },
        { "name": "Olive oil", "quantity": 2.0, "unit": "tbsp" },
        { "name": "Garlic cloves", "quantity": 3.0, "unit": "whole" },
        { "name": "Fresh rosemary", "quantity": 1.0, "unit": "tbsp" },
        { "name": "Fresh thyme", "quantity": 1.0, "unit": "tbsp" },
        { "name": "Salt", "quantity": 1.0, "unit": "tsp" },
        { "name": "Black pepper", "quantity": 0.5, "unit": "tsp" }
      ],
      "steps": [
        { "orderIndex": 1, "instruction": "Whisk together lemon juice, olive oil, minced garlic, rosemary, thyme, salt, and pepper." },
        { "orderIndex": 2, "instruction": "Coat chicken breasts in marinade and refrigerate for at least 30 minutes." },
        { "orderIndex": 3, "instruction": "Preheat grill to medium-high heat and oil the grates." },
        { "orderIndex": 4, "instruction": "Grill chicken for 6–7 minutes per side until internal temperature reaches 74°C (165°F)." },
        { "orderIndex": 5, "instruction": "Rest for 5 minutes before slicing and serving." }
      ]
    },
    {
      "uuid": "a1b2c3d4-0000-0000-0000-000000000003",
      "title": "Thai Green Curry",
      "description": "Aromatic green curry with coconut milk, vegetables, and fragrant Thai basil.",
      "imageUrl": "https://plus.unsplash.com/premium_photo-1713089366140-814130d69933?q=80&w=1740&auto=format&fit=crop",
      "imageUrlThumbnail": "https://plus.unsplash.com/premium_photo-1713089366140-814130d69933?q=80&w=1740&auto=format&fit=crop",
      "prepTimeMinutes": 15,
      "cookTimeMinutes": 25,
      "servings": 4,
      "creatorId": "c0000000-0000-0000-0000-000000000001",
      "privacy": "PUBLIC",
      "updatedAt": 1735689600000,
      "tagIds": ["a1b2c3d4-0001-0000-0000-000000000001", "a1b2c3d4-0001-0000-0000-000000000004"],
      "labelIds": ["a1b2c3d4-0002-0000-0000-000000000001", "a1b2c3d4-0002-0000-0000-000000000004"],
      "ingredients": [
        { "name": "Coconut milk", "quantity": 400.0, "unit": "ml" },
        { "name": "Green curry paste", "quantity": 2.0, "unit": "tbsp" },
        { "name": "Chicken thighs", "quantity": 500.0, "unit": "g" },
        { "name": "Zucchini", "quantity": 1.0, "unit": "whole" },
        { "name": "Red bell pepper", "quantity": 1.0, "unit": "whole" },
        { "name": "Thai basil leaves", "quantity": 0.5, "unit": "cup" },
        { "name": "Fish sauce", "quantity": 2.0, "unit": "tbsp" },
        { "name": "Palm sugar", "quantity": 1.0, "unit": "tsp" },
        { "name": "Vegetable oil", "quantity": 1.0, "unit": "tbsp" },
        { "name": "Lime juice", "quantity": 1.0, "unit": "tbsp" }
      ],
      "steps": [
        { "orderIndex": 1, "instruction": "Heat oil in a wok over medium heat. Fry curry paste for 1–2 minutes until fragrant." },
        { "orderIndex": 2, "instruction": "Add chicken pieces and cook until sealed on all sides, about 4 minutes." },
        { "orderIndex": 3, "instruction": "Pour in coconut milk and bring to a gentle simmer." },
        { "orderIndex": 4, "instruction": "Add zucchini and bell pepper. Season with fish sauce, palm sugar, and lime juice." },
        { "orderIndex": 5, "instruction": "Simmer for 15 minutes until chicken is cooked through and vegetables are tender." },
        { "orderIndex": 6, "instruction": "Stir in Thai basil leaves and serve with steamed jasmine rice." }
      ]
    },
    {
      "uuid": "a1b2c3d4-0000-0000-0000-000000000004",
      "title": "Classic Margherita Pizza",
      "description": "Simple and delicious pizza with San Marzano tomatoes, fresh mozzarella, and basil.",
      "imageUrl": "https://raw.githubusercontent.com/jmuci/ChATestAPI/refs/heads/main/statics/thumbnails/lowres/pizza-marg .jpeg",
      "imageUrlThumbnail": "https://raw.githubusercontent.com/jmuci/ChATestAPI/refs/heads/main/statics/thumbnails/lowres/pizza-marg .jpeg",
      "prepTimeMinutes": 20,
      "cookTimeMinutes": 15,
      "servings": 2,
      "creatorId": "c0000000-0000-0000-0000-000000000001",
      "privacy": "PUBLIC",
      "updatedAt": 1735689600000,
      "tagIds": ["a1b2c3d4-0001-0000-0000-000000000005", "a1b2c3d4-0001-0000-0000-000000000001"],
      "labelIds": ["a1b2c3d4-0002-0000-0000-000000000005", "a1b2c3d4-0002-0000-0000-000000000006"],
      "ingredients": [
        { "name": "Pizza dough", "quantity": 250.0, "unit": "g" },
        { "name": "San Marzano tomatoes", "quantity": 200.0, "unit": "g" },
        { "name": "Fresh mozzarella", "quantity": 150.0, "unit": "g" },
        { "name": "Fresh basil leaves", "quantity": 10.0, "unit": "whole" },
        { "name": "Olive oil", "quantity": 2.0, "unit": "tbsp" },
        { "name": "Salt", "quantity": 0.5, "unit": "tsp" }
      ],
      "steps": [
        { "orderIndex": 1, "instruction": "Preheat oven to 250°C (480°F) with a pizza stone or baking sheet inside." },
        { "orderIndex": 2, "instruction": "Stretch dough into a 30 cm round on a floured surface." },
        { "orderIndex": 3, "instruction": "Crush tomatoes by hand and spread over the dough, leaving a 2 cm border. Season with salt and drizzle with olive oil." },
        { "orderIndex": 4, "instruction": "Tear mozzarella into pieces and scatter over the sauce." },
        { "orderIndex": 5, "instruction": "Bake for 12–15 minutes until crust is golden and cheese is bubbling." },
        { "orderIndex": 6, "instruction": "Top with fresh basil leaves and a drizzle of olive oil before serving." }
      ]
    },
    {
      "uuid": "a1b2c3d4-0000-0000-0000-000000000005",
      "title": "Classic Beef Stew",
      "description": "Hearty slow-cooked beef stew with root vegetables and rich gravy.",
      "imageUrl": "https://images.unsplash.com/photo-1608500218861-01091cdc501e?q=80&w=987&auto=format&fit=crop",
      "imageUrlThumbnail": "https://images.unsplash.com/photo-1608500218861-01091cdc501e?q=80&w=987&auto=format&fit=crop",
      "prepTimeMinutes": 15,
      "cookTimeMinutes": 20,
      "servings": 4,
      "creatorId": "c0000000-0000-0000-0000-000000000001",
      "privacy": "PUBLIC",
      "updatedAt": 1735689600000,
      "tagIds": ["a1b2c3d4-0001-0000-0000-000000000008", "a1b2c3d4-0001-0000-0000-000000000009"],
      "labelIds": ["a1b2c3d4-0002-0000-0000-000000000007"],
      "ingredients": [
        { "name": "Beef chuck", "quantity": 700.0, "unit": "g" },
        { "name": "Carrots", "quantity": 3.0, "unit": "whole" },
        { "name": "Potatoes", "quantity": 3.0, "unit": "whole" },
        { "name": "Onion", "quantity": 1.0, "unit": "whole" },
        { "name": "Beef broth", "quantity": 500.0, "unit": "ml" },
        { "name": "Tomato paste", "quantity": 2.0, "unit": "tbsp" },
        { "name": "Flour", "quantity": 2.0, "unit": "tbsp" },
        { "name": "Olive oil", "quantity": 2.0, "unit": "tbsp" },
        { "name": "Fresh thyme", "quantity": 3.0, "unit": "sprigs" },
        { "name": "Bay leaves", "quantity": 2.0, "unit": "whole" }
      ],
      "steps": [
        { "orderIndex": 1, "instruction": "Cut beef into 3 cm cubes. Season with salt and pepper, then dust with flour." },
        { "orderIndex": 2, "instruction": "Heat oil in a heavy pot and brown beef in batches. Remove and set aside." },
        { "orderIndex": 3, "instruction": "In the same pot, sauté diced onion until softened. Stir in tomato paste and cook for 1 minute." },
        { "orderIndex": 4, "instruction": "Return beef to pot. Add broth, thyme, and bay leaves. Bring to a boil." },
        { "orderIndex": 5, "instruction": "Reduce heat, cover, and simmer for 1.5 hours until beef is tender." },
        { "orderIndex": 6, "instruction": "Add chopped carrots and potatoes. Simmer uncovered for 30 more minutes. Discard bay leaves and thyme before serving." }
      ]
    },
    {
      "uuid": "a1b2c3d4-0000-0000-0000-000000000006",
      "title": "Traditional Carbonara Pasta",
      "description": "Rich and creamy carbonara made with guanciale, pecorino, and egg yolks.",
      "imageUrl": "https://raw.githubusercontent.com/jmuci/ChATestAPI/refs/heads/main/statics/thumbnails/lowres/pasta-carbonara2.jpeg",
      "imageUrlThumbnail": "https://raw.githubusercontent.com/jmuci/ChATestAPI/refs/heads/main/statics/thumbnails/lowres/pasta-carbonara2.jpeg",
      "prepTimeMinutes": 10,
      "cookTimeMinutes": 25,
      "servings": 6,
      "creatorId": "c0000000-0000-0000-0000-000000000001",
      "privacy": "PUBLIC",
      "updatedAt": 1735689600000,
      "tagIds": ["a1b2c3d4-0001-0000-0000-000000000006", "a1b2c3d4-0001-0000-0000-000000000007"],
      "labelIds": ["a1b2c3d4-0002-0000-0000-000000000008"],
      "ingredients": [
        { "name": "Spaghetti", "quantity": 400.0, "unit": "g" },
        { "name": "Guanciale", "quantity": 150.0, "unit": "g" },
        { "name": "Egg yolks", "quantity": 4.0, "unit": "whole" },
        { "name": "Whole egg", "quantity": 1.0, "unit": "whole" },
        { "name": "Pecorino Romano", "quantity": 80.0, "unit": "g" },
        { "name": "Black pepper", "quantity": 1.0, "unit": "tsp" }
      ],
      "steps": [
        { "orderIndex": 1, "instruction": "Cook spaghetti in heavily salted boiling water until al dente. Reserve 200 ml of pasta water." },
        { "orderIndex": 2, "instruction": "Cut guanciale into lardons and cook in a dry pan over medium heat until crispy. Set aside." },
        { "orderIndex": 3, "instruction": "Whisk egg yolks, whole egg, and grated pecorino together. Add a generous amount of cracked black pepper." },
        { "orderIndex": 4, "instruction": "Remove pan from heat. Add drained pasta to the guanciale pan and toss." },
        { "orderIndex": 5, "instruction": "Off the heat, pour egg mixture over pasta, adding reserved pasta water a splash at a time, tossing vigorously to create a creamy sauce." },
        { "orderIndex": 6, "instruction": "Serve immediately topped with more pecorino and black pepper." }
      ]
    },
    {
      "uuid": "a1b2c3d4-0000-0000-0000-000000000007",
      "title": "Lasagna Bolognese",
      "description": "Classic layered lasagna with rich Bolognese meat sauce and creamy béchamel.",
      "imageUrl": "https://raw.githubusercontent.com/jmuci/ChATestAPI/refs/heads/main/statics/thumbnails/lowres/lasagne.jpeg",
      "imageUrlThumbnail": "https://raw.githubusercontent.com/jmuci/ChATestAPI/refs/heads/main/statics/thumbnails/lowres/lasagne.jpeg",
      "prepTimeMinutes": 20,
      "cookTimeMinutes": 30,
      "servings": 4,
      "creatorId": "c0000000-0000-0000-0000-000000000001",
      "privacy": "PUBLIC",
      "updatedAt": 1735689600000,
      "tagIds": ["a1b2c3d4-0001-0000-0000-000000000014"],
      "labelIds": [],
      "ingredients": [
        { "name": "Lasagna sheets", "quantity": 12.0, "unit": "whole" },
        { "name": "Ground beef", "quantity": 400.0, "unit": "g" },
        { "name": "Crushed tomatoes", "quantity": 400.0, "unit": "g" },
        { "name": "Whole milk", "quantity": 500.0, "unit": "ml" },
        { "name": "Butter", "quantity": 40.0, "unit": "g" },
        { "name": "Flour", "quantity": 40.0, "unit": "g" },
        { "name": "Parmesan", "quantity": 80.0, "unit": "g" },
        { "name": "Onion", "quantity": 1.0, "unit": "whole" },
        { "name": "Olive oil", "quantity": 2.0, "unit": "tbsp" },
        { "name": "Nutmeg", "quantity": 0.25, "unit": "tsp" }
      ],
      "steps": [
        { "orderIndex": 1, "instruction": "Sauté diced onion in olive oil until soft. Add ground beef and brown well. Stir in crushed tomatoes, season, and simmer for 20 minutes." },
        { "orderIndex": 2, "instruction": "Make béchamel: melt butter, stir in flour, cook for 1 minute, then gradually whisk in milk. Simmer until thickened. Season with salt and nutmeg." },
        { "orderIndex": 3, "instruction": "Preheat oven to 190°C (375°F). Spread a thin layer of Bolognese on the bottom of a baking dish." },
        { "orderIndex": 4, "instruction": "Layer lasagna sheets, Bolognese, then béchamel. Repeat layers, finishing with béchamel on top." },
        { "orderIndex": 5, "instruction": "Sprinkle Parmesan over the top and bake for 35–40 minutes until golden and bubbling." },
        { "orderIndex": 6, "instruction": "Rest for 10 minutes before cutting and serving." }
      ]
    },
    {
      "uuid": "a1b2c3d4-0000-0000-0000-000000000008",
