    },
    {
      "uuid": "a1b2c3d4-0000-0000-0000-000000000009",
      "title": "Grilled Salmon Teriyaki",
      "description": "Glazed salmon fillet with a sweet and savory teriyaki sauce.",
      "imageUrl": "https://raw.githubusercontent.com/jmuci/ChATestAPI/refs/heads/main/statics/thumbnails/lowres/salmon-ter.jpeg",
      "imageUrlThumbnail": "https://raw.githubusercontent.com/jmuci/ChATestAPI/refs/heads/main/statics/thumbnails/lowres/salmon-ter.jpeg",
      "prepTimeMinutes": 10,
      "cookTimeMinutes": 15,
      "servings": 2,
      "creatorId": "c0000000-0000-0000-0000-000000000001",
      "privacy": "PUBLIC",
      "updatedAt": 1735689600000,
      "tagIds": ["a1b2c3d4-0001-0000-0000-000000000001", "a1b2c3d4-0001-0000-0000-000000000010"],
      "labelIds": ["a1b2c3d4-0002-0000-0000-000000000009", "a1b2c3d4-0002-0000-0000-000000000004"],
      "ingredients": [
        { "name": "Salmon fillets", "quantity": 2.0, "unit": "whole" },
        { "name": "Soy sauce", "quantity": 3.0, "unit": "tbsp" },
        { "name": "Mirin", "quantity": 2.0, "unit": "tbsp" },
        { "name": "Sake", "quantity": 1.0, "unit": "tbsp" },
        { "name": "Sugar", "quantity": 1.0, "unit": "tbsp" },
        { "name": "Sesame oil", "quantity": 1.0, "unit": "tsp" },
        { "name": "Spring onion", "quantity": 2.0, "unit": "whole" },
        { "name": "Sesame seeds", "quantity": 1.0, "unit": "tsp" }
      ],
      "steps": [
        { "orderIndex": 1, "instruction": "Mix soy sauce, mirin, sake, and sugar in a small saucepan. Simmer over low heat for 2–3 minutes until slightly thickened. Stir in sesame oil." },
        { "orderIndex": 2, "instruction": "Pat salmon fillets dry and brush with half the teriyaki sauce." },
        { "orderIndex": 3, "instruction": "Grill or pan-sear salmon skin-side down over medium-high heat for 4 minutes." },
