      "labelIds": ["a1b2c3d4-0002-0000-0000-000000000008"],
      "ingredients": [
        { "name": "Penne pasta", "quantity": 400.0, "unit": "g" },
        { "name": "Italian sausage", "quantity": 300.0, "unit": "g" },
        { "name": "Sun-dried tomatoes", "quantity": 80.0, "unit": "g" },
        { "name": "Heavy cream", "quantity": 200.0, "unit": "ml" },
        { "name": "Garlic cloves", "quantity": 4.0, "unit": "whole" },
        { "name": "Baby spinach", "quantity": 60.0, "unit": "g" },
        { "name": "Parmesan", "quantity": 60.0, "unit": "g" },
        { "name": "Olive oil", "quantity": 1.0, "unit": "tbsp" },
        { "name": "Red chili flakes", "quantity": 0.5, "unit": "tsp" }
      ],
      "steps": [
        { "orderIndex": 1, "instruction": "Cook penne in salted boiling water until al dente. Reserve 100 ml pasta water." },
        { "orderIndex": 2, "instruction": "Remove sausage from casings and cook in olive oil over medium-high heat, breaking into pieces, until browned." },
        { "orderIndex": 3, "instruction": "Add minced garlic and chili flakes; cook for 1 minute. Stir in sun-dried tomatoes." },
